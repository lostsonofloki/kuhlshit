# Public site URL for absolute OG/image URLs in dev (optional). Production: set in Vercel to https://kuhlshit.com
# VITE_SITE_ORIGIN=https://kuhlshit.com

# Dev server / HMR (optional). If the browser URL port differs from the Vite port (e.g. Cursor port forward),
# set both so WebSocket HMR matches the page: PORT=3001 and VITE_HMR_CLIENT_PORT=3001
# PORT=3000
# VITE_HMR_CLIENT_PORT=

# YouTube API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
#
# Production / Preview: add the same variables in the Vercel project
# (Settings → Environment Variables). Vite only exposes names prefixed with VITE_.

VITE_YOUTUBE_API_KEY=your_api_key_here
VITE_YOUTUBE_PLAYLIST_ID=PLzKakvgn9O5SVJcmGFIRc77zk8Asib1Ek
